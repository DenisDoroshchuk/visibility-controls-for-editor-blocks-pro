#. Description of the plugin
#: visibility-controls-for-editor-blocks.php
msgid "Adds controls to hide blocks on mobile, tablet, and desktop devices in Gutenberg."
msgstr "Добавляет элементы управления для скрытия блоков на мобильных, планшетных и настольных устройствах в Gutenberg."

#: visibility-controls-for-editor-blocks.php:360
msgid "Advanced Settings"
msgstr "Расширенные настройки"

#: visibility-controls-for-editor-blocks.php:412
msgid "Any screen wider than the tablet breakpoint will be considered a desktop."
msgstr "Любой экран, ширина которого превышает значение контрольной точки планшета, будет считаться настольным устройством."

#: visibility-controls-for-editor-blocks.php:400
msgid "Blocks hidden on mobile will be hidden on screens this size or smaller."
msgstr "Блоки, скрытые на мобильных устройствах, будут скрыты на экранах заданного размера или меньше."

#: visibility-controls-for-editor-blocks.php:407
msgid "Blocks hidden on tablets will be hidden on screens this size or smaller."
msgstr "Блоки, скрытые на планшетах, будут скрыты на экранах заданного размера или меньше."

#: visibility-controls-for-editor-blocks.php:348
msgid "Breakpoints Settings"
msgstr "Настройки контрольных точек"

#: src/controls/visibility-panel.js:82
msgid "Configure Breakpoints"
msgstr "Настройки контрольных точек"

#: visibility-controls-for-editor-blocks.php:380
msgid "Configure the breakpoints for mobile, tablet and desktop devices."
msgstr "Настройте контрольные точки для мобильных, планшетных и настольных устройств."

#: visibility-controls-for-editor-blocks.php:357
msgid "Desktop Breakpoint (px)"
msgstr "Контрольная точка для настольных устройств (px)"

#: visibility-controls-for-editor-blocks.php:392
msgid "Disable CSS loading on pages without Gutenberg"
msgstr "Отключить загрузку CSS стилей на страницах без Gutenberg блоков"

#: visibility-controls-for-editor-blocks.php:123
msgid "Gutenberg Blocks Visibility"
msgstr "Видимость Блоков Gutenberg"

#: src/index.js:75
msgid "Hidden for Logged-in Users"
msgstr "Скрыто для вошедших пользователей"

#: src/index.js:86
msgid "Hidden for Non-Logged-in Users"
msgstr "Скрыто для НЕ вошедших пользователей"

#: src/index.js:64
msgid "Hidden on Desktop"
msgstr "Скрыт на настольных устройствах"

#: src/index.js:42
msgid "Hidden on Mobile"
msgstr "Скрыт на мобильных устройствах"

#: src/index.js:53
msgid "Hidden on Tablet"
msgstr "Скрыт на планшетах"

#: src/controls/visibility-panel.js:55
msgid "Hide for Logged-in Users"
msgstr "Скрыть для вошедших пользователей"

#: src/controls/visibility-panel.js:65
msgid "Hide for Non-Logged-in Users"
msgstr "Скрыть для НЕ вошедших пользователей"

#: src/controls/visibility-panel.js:45
msgid "Hide on Desktop"
msgstr "Скрыть на настольных устройствах"

#: src/controls/visibility-panel.js:25
msgid "Hide on Mobile"
msgstr "Скрыть на мобильных устройствах"

#: src/controls/visibility-panel.js:35
msgid "Hide on Tablet"
msgstr "Скрыть на планшетах"

#: visibility-controls-for-editor-blocks.php:289
msgid "Leave a Review"
msgstr "Оставить отзыв"

#: visibility-controls-for-editor-blocks.php:351
msgid "Mobile Breakpoint (px)"
msgstr "Контрольная точка для мобильных устройств (px)"

#: visibility-controls-for-editor-blocks.php:412
msgid "Note: "
msgstr "Примечание: "

#: visibility-controls-for-editor-blocks.php:400
msgid "Recommended: between 320px and 600px for mobiles."
msgstr "Рекомендуемый размер: от 320px до 600px для мобильных устройств."

#: visibility-controls-for-editor-blocks.php:407
msgid "Recommended: between 601px and 1024px for tablets."
msgstr "Рекомендуемый размер: от 601px до 1024px для планшетов."

#: visibility-controls-for-editor-blocks.php:417
msgid "Settings"
msgstr "Настройки"

#: visibility-controls-for-editor-blocks.php:363
msgid "Styles loading"
msgstr "Загрузка стилей"

#: visibility-controls-for-editor-blocks.php:354
msgid "Tablet Breakpoint (px)"
msgstr "Контрольная точка для планшетов (px)"

#: visibility-controls-for-editor-blocks.php:412
msgid "There's no input for the desktop breakpoint because it is automatically defined"
msgstr "Контрольную точку для настольных устройств вводить не нужно, поскольку она определяется автоматически"

#: visibility-controls-for-editor-blocks.php:393
msgid "This includes archive pages such as categories and tags, as well as other pages that do not contain Gutenberg blocks."
msgstr "Сюда входят архивные страницы, такие как категории и теги, а также другие страницы, не содержащие блоков Gutenberg."

#: visibility-controls-for-editor-blocks.php:400
msgid "This option defines the screen width (in pixels) that determines a mobile device."
msgstr "Этот параметр задает ширину экрана (в пикселях), которую определяет мобильное устройство."

#: visibility-controls-for-editor-blocks.php:407
msgid "This option defines the screen width (in pixels) that determines a tablet device."
msgstr "Этот параметр задает ширину экрана (в пикселях), которая определяет планшетное устройство."

#. Plugin Name of the plugin
#: visibility-controls-for-editor-blocks.php
msgid "Visibility Controls for Editor Blocks"
msgstr "Контроль видимости для Gutenberg блоков"

#: visibility-controls-for-editor-blocks.php:123
msgid "Visibility Controls for Gutenberg Blocks"
msgstr "Контроль видимости для Gutenberg блоков"

#: src/controls/visibility-panel.js:19
msgid "Visibility Settings"
msgstr "Настройки видимости"

#: visibility-controls-for-editor-blocks.php:393
msgid "When this option is enabled, the plugin will prevent loading its CSS code on pages that do not use the Gutenberg editor."
msgstr "Если эта опция включена, плагин не будет загружать CSS стили на страницах, не использующих редактор Gutenberg."

#: visibility-controls-for-editor-blocks.php:315
msgid "Video guide"
msgstr "Видеоинструкция"

#: visibility-controls-for-editor-blocks.php:316
msgid "Watch short tutorials for setting up block visibility rules."
msgstr "Посмотрите короткие инструкции по настройке правил видимости блоков."

#: visibility-controls-for-editor-blocks.php:323
msgid "Open video playlist"
msgstr "Открыть плейлист с видео"

#: visibility-controls-for-editor-blocks.php:283
msgid "Enjoying Visibility Controls?"
msgstr "Нравится Visibility Controls?"

#: visibility-controls-for-editor-blocks.php:284
msgid "If this plugin saves you time, a quick review on WordPress.org helps other Gutenberg users find it."
msgstr "Если плагин экономит вам время, короткий отзыв на WordPress.org поможет другим пользователям Gutenberg его найти."

